# Copy to .env only if you need to override the defaults. The committed
# defaults match the models pre-installed on the TCS-issued laptops:
# `qwen-2.5.1-coder-it:latest` for generation, `gte-large:latest` for embeddings.

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen-2.5.1-coder-it:latest
EMBEDDING_MODEL=gte-large:latest

# ChromaDB persistence (relative to backend/)
CHROMA_PERSIST_DIR=./vectorstore/chroma_db
CHROMA_COLLECTION=incidents

# CORS — comma-separated, used by FastAPI
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
